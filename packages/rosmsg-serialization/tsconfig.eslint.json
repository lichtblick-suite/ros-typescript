// -*- jsonc -*-
// tsconfig for eslint
{
  "extends": "@lichtblick/tsconfig/base.json",
  "include": ["./src/**/*", "./bench/**/*"],
  "compilerOptions": {
    "lib": ["DOM", "es2020"],
    "verbatimModuleSyntax": false,
    "isolatedDeclarations": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node"]
  }
}
